{
  "manifest_version": 3,
  "name": "Rsbuild Chrome Extension — Lazy Loading Config",
  "version": "0.1.0",
  "description": "Reference config: lazy loading (code splitting) in Chrome Extension content script via Rsbuild + bootstrap pattern",

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["bootstrap.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": [
        "content.js",
        "chunks/*.js",
        "chunks/*.css"
      ],
      "use_dynamic_url": false
    }
  ],

  "permissions": []
}
